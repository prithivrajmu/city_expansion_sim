{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulation Command",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["upzone_district", "build_transit", "flood_barrier"]
    },
    "district": {
      "type": "string"
    },
    "strength": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 1
    }
  }
}
