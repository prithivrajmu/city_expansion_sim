{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "City Expansion Scenario",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "focus",
    "baseYear",
    "ticksPerYear",
    "gridWidth",
    "gridHeight",
    "policyBoost",
    "residentDemand",
    "developerPressure",
    "infrastructureMomentum",
    "horizonTicks",
    "objectives",
    "initialBudget",
    "initialPoliticalCapital",
    "agentProfiles",
    "events",
    "cells"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "focus": { "type": "string" },
    "baseYear": { "type": "integer" },
    "ticksPerYear": { "type": "integer", "minimum": 1 },
    "gridWidth": { "type": "integer", "minimum": 1 },
    "gridHeight": { "type": "integer", "minimum": 1 },
    "policyBoost": { "type": "number" },
    "residentDemand": { "type": "number" },
    "developerPressure": { "type": "number" },
    "infrastructureMomentum": { "type": "number" },
    "horizonTicks": { "type": "integer", "minimum": 1 },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "metric", "target"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "metric": { "type": "string" },
          "target": { "type": "number" },
          "comparator": { "type": "string", "enum": ["at_least", "at_most"] }
        }
      }
    },
    "initialBudget": { "type": "integer", "minimum": 0 },
    "initialPoliticalCapital": { "type": "integer", "minimum": 0 },
    "agentProfiles": {
      "type": "object",
      "properties": {
        "residents": { "type": "object" },
        "developers": { "type": "object" },
        "government": { "type": "object" }
      }
    },
    "districtAgents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "residentDemandBias": { "type": "number" },
          "developerIntensity": { "type": "number" },
          "governmentSupport": { "type": "number" },
          "policyFriction": { "type": "number" },
          "resiliencePriority": { "type": "number" }
        }
      }
    },
    "districtStrategies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["balanced", "growth_first", "resilience_first"]
          },
          "growth_signal_bias": { "type": "number" },
          "conversion_threshold_delta": { "type": "number" },
          "access_drift": { "type": "number" },
          "land_value_multiplier": { "type": "number" },
          "population_multiplier": { "type": "number" },
          "risk_drift": { "type": "number" },
          "risk_weight": { "type": "number" }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tick", "title", "impact"],
        "properties": {
          "tick": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "district": { "type": "string" },
          "impact": { "type": "object" }
        }
      }
    },
    "cells": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["district", "kind", "urbanized", "population", "landValue", "risk", "access"],
        "properties": {
          "district": { "type": "string" },
          "kind": { "type": "string" },
          "urbanized": { "type": "boolean" },
          "population": { "type": "integer" },
          "landValue": { "type": "integer" },
          "risk": { "type": "number" },
          "access": { "type": "number" }
        }
      }
    }
  }
}
