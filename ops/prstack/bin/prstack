#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
STATE_DIR="${ROOT_DIR}/ops/prstack/state"
TEMPLATE_DIR="${ROOT_DIR}/ops/prstack/templates"
REPORT_DIR="${STATE_DIR}/reports"
SLICE_DIR="${STATE_DIR}/slices"
NOW="$(date +%F)"

render_template() {
  local template_path="$1"
  local output_path="$2"
  local title="${3:-Current Implementation Slice}"

  sed \
    -e "s/{{DATE}}/${NOW}/g" \
    -e "s/{{TITLE}}/${title}/g" \
    "${template_path}" > "${output_path}"
}

usage() {
  cat <<'EOF'
Usage:
  prstack bootstrap
  prstack install
  prstack dev
  prstack plan "Title"
  prstack slice "Title"
  prstack ralph-ping
  prstack loop [n] [--no-commit]
  prstack ceo-review
  prstack security-review
  prstack review
  prstack qa
  prstack ship
  prstack handoff
  prstack status
EOF
}

bootstrap() {
  mkdir -p "${STATE_DIR}" "${REPORT_DIR}" "${SLICE_DIR}"

  if [[ ! -f "${STATE_DIR}/mission.md" ]]; then
    cp "${TEMPLATE_DIR}/mission.md" "${STATE_DIR}/mission.md"
  fi

  if [[ ! -f "${STATE_DIR}/tasks.md" ]]; then
    cp "${TEMPLATE_DIR}/tasks.md" "${STATE_DIR}/tasks.md"
  fi

  if [[ ! -f "${STATE_DIR}/current-slice.md" ]]; then
    render_template "${TEMPLATE_DIR}/current-slice.md" "${STATE_DIR}/current-slice.md"
  fi

  if [[ ! -f "${REPORT_DIR}/review.md" ]]; then
    render_template "${TEMPLATE_DIR}/review.md" "${REPORT_DIR}/review.md"
  fi

  if [[ ! -f "${REPORT_DIR}/qa.md" ]]; then
    render_template "${TEMPLATE_DIR}/qa.md" "${REPORT_DIR}/qa.md"
  fi

  if [[ ! -f "${REPORT_DIR}/ceo-review.md" ]]; then
    render_template "${TEMPLATE_DIR}/ceo-review.md" "${REPORT_DIR}/ceo-review.md"
  fi

  if [[ ! -f "${REPORT_DIR}/security-review.md" ]]; then
    render_template "${TEMPLATE_DIR}/security-review.md" "${REPORT_DIR}/security-review.md"
  fi

  if [[ ! -f "${REPORT_DIR}/handoff.md" ]]; then
    render_template "${TEMPLATE_DIR}/handoff.md" "${REPORT_DIR}/handoff.md"
  fi

  printf 'Initialized prstack state in %s\n' "${STATE_DIR}"
}

status() {
  bootstrap >/dev/null

  printf 'Repo: %s\n' "${ROOT_DIR}"
  printf 'Mission: %s\n' "${STATE_DIR}/mission.md"
  printf 'Tasks: %s\n' "${STATE_DIR}/tasks.md"
  printf 'Current Slice: %s\n' "${STATE_DIR}/current-slice.md"
  printf 'Review Report: %s\n' "${REPORT_DIR}/review.md"
  printf 'QA Report: %s\n' "${REPORT_DIR}/qa.md"
  printf 'CEO Review: %s\n' "${REPORT_DIR}/ceo-review.md"
  printf 'Security Review: %s\n' "${REPORT_DIR}/security-review.md"
  printf 'Handoff: %s\n' "${REPORT_DIR}/handoff.md"

  if [[ -f "${STATE_DIR}/tasks.md" ]]; then
    printf '\nOpen tasks:\n'
    grep '^\- \[ \]' "${STATE_DIR}/tasks.md" || true
  fi
}

install() {
  (cd "${ROOT_DIR}" && npm run setup:all)
}

ensure_ralph() {
  if [[ ! -x "${ROOT_DIR}/node_modules/.bin/ralph" ]]; then
    printf 'Ralph is not installed locally. Run prstack install or npm install.\n' >&2
    exit 1
  fi
  if [[ ! -f "${ROOT_DIR}/.agents/ralph/loop.sh" ]]; then
    printf 'Ralph templates are missing from .agents/ralph.\n' >&2
    exit 1
  fi
}

dev() {
  bootstrap

  if [[ ! -d "${ROOT_DIR}/node_modules" || ! -d "${ROOT_DIR}/frontend/node_modules" || ! -d "${ROOT_DIR}/backend/.venv" ]]; then
    printf 'Dependencies missing. Running prstack install first.\n'
    install
  fi

  (cd "${ROOT_DIR}" && npm run dev)
}

ralph_ping() {
  bootstrap >/dev/null
  ensure_ralph
  (cd "${ROOT_DIR}" && npx ralph ping --agent=codex)
}

plan() {
  bootstrap >/dev/null
  local title="${1:-Current Implementation Slice}"
  render_template "${TEMPLATE_DIR}/current-slice.md" "${STATE_DIR}/current-slice.md" "${title}"
  printf 'Updated current slice: %s\n' "${STATE_DIR}/current-slice.md"
}

slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//'
}

slice() {
  bootstrap >/dev/null
  local title="${1:-Implementation Slice}"
  local slug
  slug="$(slugify "${title}")"
  local output="${SLICE_DIR}/${NOW}-${slug}.md"
  render_template "${TEMPLATE_DIR}/current-slice.md" "${output}" "${title}"
  cp "${output}" "${STATE_DIR}/current-slice.md"
  printf 'Created slice: %s\n' "${output}"
}

review() {
  bootstrap >/dev/null
  local frontend_status="pass"
  local backend_status="pass"
  local frontend_output
  local backend_output

  if ! frontend_output="$(cd "${ROOT_DIR}/frontend" && npm run build 2>&1)"; then
    frontend_status="fail"
  fi

  if ! backend_output="$(cd "${ROOT_DIR}/backend" && uv run --with pytest pytest -q 2>&1)"; then
    backend_status="fail"
  fi

  cat > "${REPORT_DIR}/review.md" <<EOF
# Review Report

## Date

${NOW}

## Summary

- frontend build: ${frontend_status}
- backend tests: ${backend_status}

## Checks

- frontend build: ${frontend_status}
- backend tests: ${backend_status}

## Findings

$(if [[ "${frontend_status}" == "pass" && "${backend_status}" == "pass" ]]; then
    printf '%s\n' '- No automated review findings from the current build-and-test pass.'
  else
    printf '%s\n' '- Automated review detected at least one failing verification step.'
  fi)

## Raw Output

\`\`\`
${frontend_output}

${backend_output}
\`\`\`
EOF

  printf 'Wrote review report: %s\n' "${REPORT_DIR}/review.md"
  [[ "${frontend_status}" == "pass" && "${backend_status}" == "pass" ]]
}

qa() {
  bootstrap >/dev/null
  local api_status="pass"
  local qa_output

  if ! qa_output="$(cd "${ROOT_DIR}/backend" && uv run python - <<'PY'
from app.server import app

client = app.test_client()
health = client.get("/health")
assert health.status_code == 200
scenarios = client.get("/scenarios")
assert scenarios.status_code == 200
payload = client.post("/sessions", json={"scenarioId": "metro_delta_arc"}).get_json()
sid = payload["sessionId"]
client.post(f"/sessions/{sid}/commands", json={"type": "flood_barrier", "district": "Low Basin", "strength": 0.14})
tick = client.post(f"/sessions/{sid}/tick", json={"steps": 3})
assert tick.status_code == 200
report = client.get(f"/sessions/{sid}/report")
assert report.status_code == 200
print("health ok")
print("scenario count", len(scenarios.get_json()["items"]))
print("tick", tick.get_json()["snapshot"]["tick"])
print("headline", report.get_json()["headline"])
PY
 2>&1)"; then
    api_status="fail"
  fi

  cat > "${REPORT_DIR}/qa.md" <<EOF
# QA Report

## Date

${NOW}

## Summary

- api smoke: ${api_status}

## Coverage

- health endpoint
- scenario catalog
- session creation
- command application
- report generation

## Notes

\`\`\`
${qa_output}
\`\`\`
EOF

  printf 'Wrote QA report: %s\n' "${REPORT_DIR}/qa.md"
  [[ "${api_status}" == "pass" ]]
}

ceo_review() {
  bootstrap >/dev/null
  cat > "${REPORT_DIR}/ceo-review.md" <<EOF
# CEO Review

## Date

${NOW}

## Product Position

- The sim has a working city-systems sandbox with scenarios, interventions, replay, save/load, and reports.
- The current experience is still a systems demo, not yet a sticky strategy product loop.
- The strongest product angle is "urban strategy lab": compare policy choices, district strategies, and long-horizon tradeoffs.

## What Is Working

- Fast setup through \`prstack dev\`
- Clear simulation verbs: transit, upzoning, flood barriers
- Scenario-driven structure with event timelines
- Replay and save/load strong enough for experimentation

## Missing To Reach A Real Product

- No explicit win/loss or score model for player decisions
- No side-by-side comparison run for "what changed because of my intervention"
- No budget, political capital, or resource constraints on commands
- No campaign or scenario progression that teaches the system over time
- Long-term world model is still unresolved: district abstraction works, but tile or hybrid detail is still undecided

## Direction

- Keep the district model as the shipping core and defer tile detail until a stronger game loop exists
- Build a comparison panel next: baseline versus current run, delta by district, and intervention ROI
- Add resource constraints so each intervention becomes a tradeoff instead of a free action
- Introduce scenario objectives and failure pressure so reports become decisions, not just telemetry

## Immediate Priorities

- Build baseline-vs-run comparison UX and API output
- Add budget and policy-capital costs to interventions
- Define scenario objectives, success metrics, and end-of-horizon evaluation
- Decide whether district-only remains the production model or becomes a layer over future tiles
EOF

  printf 'Wrote CEO review: %s\n' "${REPORT_DIR}/ceo-review.md"
}

security_review() {
  bootstrap >/dev/null
  cat > "${REPORT_DIR}/security-review.md" <<EOF
# Security Review

## Date

${NOW}

## Overall Assessment

- Current risk posture: prototype-grade
- Main exposure is backend trust of user input rather than infrastructure complexity

## Findings

- High: scenario and save identifiers are user-controlled entry points and must be strictly validated to avoid path traversal and unexpected file access
- High: the API is fully unauthenticated and CORS-open, which is fine for local development but not safe for any shared or hosted deployment
- Medium: save listings expose internal filesystem paths, which leaks host layout without product value
- Medium: session growth is unbounded in memory, so repeated session creation can become a denial-of-service vector
- Medium: error handling is inconsistent, so malformed input can surface framework exceptions instead of controlled API responses

## Guidance

- Keep local-dev defaults, but add explicit production guards before any public deployment
- Treat scenario ids, save ids, and command payloads as schema-validated inputs rather than trusted strings
- Stop returning host paths in public payloads unless an internal tool genuinely needs them
- Add bounded in-memory session retention or persistence-backed eviction
- Add structured 4xx responses for invalid session ids, ticks, commands, and save ids

## Next Security Work

- Add input validation and normalized error responses across the API
- Add a deployment mode with restricted CORS and basic auth/session protection
- Add rate limiting or session caps before exposing the backend outside localhost
- Add schema validation for command payloads and save labels
EOF

  printf 'Wrote security review: %s\n' "${REPORT_DIR}/security-review.md"
}

loop() {
  bootstrap >/dev/null
  ensure_ralph
  local iterations="1"
  local no_commit=""

  if [[ $# -ge 1 && "$1" =~ ^[0-9]+$ ]]; then
    iterations="$1"
    shift
  fi

  if [[ "${1:-}" == "--no-commit" ]]; then
    no_commit="--no-commit"
  fi

  printf 'Running Ralph loop for %s iteration(s)%s\n' "${iterations}" "${no_commit:+ (no commit)}"
  (cd "${ROOT_DIR}" && npx ralph build "${iterations}" --agent=codex ${no_commit})

  review
  qa
  ceo_review
  security_review
  handoff
}

handoff() {
  bootstrap >/dev/null
  local title
  title="$(sed -n '5p' "${STATE_DIR}/current-slice.md" | tr -d '\r')"
  cat > "${REPORT_DIR}/handoff.md" <<EOF
# Handoff

## Date

${NOW}

## Current Slice

${title}

## Completed

- Review report refreshed at \`${REPORT_DIR}/review.md\`
- QA report refreshed at \`${REPORT_DIR}/qa.md\`
- CEO review refreshed at \`${REPORT_DIR}/ceo-review.md\`
- Security review refreshed at \`${REPORT_DIR}/security-review.md\`
- Current slice tracked at \`${STATE_DIR}/current-slice.md\`

## Next

- Continue the active slice or open a new one with \`prstack slice "Title"\`
- Use \`prstack review\` before structural merges
- Use \`prstack qa\` after simulation or API changes
- Use \`prstack ceo-review\` and \`prstack security-review\` to keep product and risk guidance current

## Risks

- Ship flow is still local-report based because this project is not yet a git repo with PR automation
EOF

  printf 'Wrote handoff report: %s\n' "${REPORT_DIR}/handoff.md"
}

ship() {
  bootstrap >/dev/null
  review
  qa
  ceo_review
  security_review
  handoff
  cat > "${REPORT_DIR}/ship.md" <<EOF
# Ship Report

## Date

${NOW}

## Status

- review completed
- qa completed
- ceo review completed
- security review completed
- handoff prepared

## Notes

- This is a local ship gate, not a PR automation workflow yet.
- Use the generated reports under \`${REPORT_DIR}\` as the release packet.
EOF
  printf 'Wrote ship report: %s\n' "${REPORT_DIR}/ship.md"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  case "$1" in
    bootstrap)
      bootstrap
      ;;
    install)
      install
      ;;
    dev)
      dev
      ;;
    plan)
      shift
      plan "${*:-Current Implementation Slice}"
      ;;
    slice)
      shift
      slice "${*:-Implementation Slice}"
      ;;
    ralph-ping)
      ralph_ping
      ;;
    loop)
      shift
      loop "$@"
      ;;
    review)
      review
      ;;
    qa)
      qa
      ;;
    ceo-review)
      ceo_review
      ;;
    security-review)
      security_review
      ;;
    ship)
      ship
      ;;
    handoff)
      handoff
      ;;
    status)
      status
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
